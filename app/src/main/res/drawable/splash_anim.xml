<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <aapt:attr name="android:drawable">
        <vector
            android:name="vector"
            android:width="288dp"
            android:height="288dp"
            android:viewportWidth="288"
            android:viewportHeight="288">
            <group
                android:name="group"
                android:pivotX="144"
                android:pivotY="144">

                <group
                    android:translateX="44"
                    android:translateY="39"
                    android:scaleX="2"
                    android:scaleY="2">

                    <path android:pathData="M38,35A12,20 0,0 1,62 35"
                        android:strokeWidth="7"
                        android:strokeLineCap="round"
                        android:fillColor="#00000000">
                        <aapt:attr name="android:strokeColor">
                            <gradient
                                android:type="linear"
                                android:startX="15"
                                android:startY="10"
                                android:endX="85"
                                android:endY="35"
                                android:startColor="#FF3F6C"
                                android:centerColor="#9B3FE0"
                                android:endColor="#FF8A3F"/>
                        </aapt:attr>
                    </path>

                    <path android:pathData="M30,35L70,35L85,95L15,95Z">
                        <aapt:attr name="android:fillColor">
                            <gradient
                                android:type="linear"
                                android:startX="15"
                                android:startY="35"
                                android:endX="85"
                                android:endY="95"
                                android:startColor="#FF3F6C"
                                android:centerColor="#9B3FE0"
                                android:endColor="#FF8A3F"/>
                        </aapt:attr>
                    </path>

                    <path
                        android:pathData="M20,63L80,63"
                        android:strokeWidth="3"
                        android:strokeColor="#ffffff"
                        android:strokeAlpha="0.4"/>

                </group>
            </group>
        </vector>
    </aapt:attr>
    <target android:name="group">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:startOffset="100"
                    android:duration="400"
                    android:valueFrom="1"
                    android:valueTo="1.15"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/fast_out_slow_in"/>
                <objectAnimator
                    android:propertyName="scaleY"
                    android:startOffset="100"
                    android:duration="400"
                    android:valueFrom="1"
                    android:valueTo="1.15"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/fast_out_slow_in"/>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:startOffset="500"
                    android:duration="500"
                    android:valueFrom="1.15"
                    android:valueTo="1"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/fast_out_slow_in"/>
                <objectAnimator
                    android:propertyName="scaleY"
                    android:startOffset="500"
                    android:duration="500"
                    android:valueFrom="1.15"
                    android:valueTo="1"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/fast_out_slow_in"/>
            </set>
        </aapt:attr>
    </target>
</animated-vector>